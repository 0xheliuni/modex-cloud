# ===== Modex Cloud — environment template =====
# Copy to .env and fill in. NEVER commit the real .env.

# HTTP port
PORT=3000

# Master encryption key — REQUIRED. 64 hex chars (AES-256).
# Generate: openssl rand -hex 32
# This key protects every sealed secret. Losing it makes pending keys
# unrecoverable; leaking it compromises sealed-at-rest secrets. Store it in a
# secrets manager / KMS, NOT in this file in production.
MASTER_KEK=

# Session signing secret — REQUIRED. >= 16 chars (use 32+).
# Generate: openssl rand -base64 32
SESSION_SECRET=

# Database. Empty = local SQLite file (modex-cloud.db).
# MySQL:    user:pass@tcp(host:3306)/modex_cloud?charset=utf8mb4&parseTime=True
# Postgres: postgres://user:pass@host:5432/modex_cloud?sslmode=require
SQL_DSN=

# Initial admin account (seeded only when the user table is empty).
# If ROOT_PASSWORD is blank, a random one is generated and printed once at startup.
ROOT_USERNAME=admin
ROOT_PASSWORD=

# Comma-less single trusted proxy CIDR (optional; for correct client IPs behind a proxy).
TRUSTED_PROXIES=
